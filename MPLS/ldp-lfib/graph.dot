graph {
  bgcolor="transparent"
  nodesep="0.5"
  ranksep="1"
  node [bgcolor="#ff9f01" fillcolor="#ff9f01" margin="0.3,0.1" shape="box" style="rounded,filled" fontname="Verdana" fontsize="11"]
  edge [fontname="Verdana" labelfontsize="8" labeldistance="1.5"]
  newrank=true;
  { rank=same; "pe1"; "pe2"; "p1"; "p2"; "h1"; "h2"; }
  "pe1" [
    label="pe1 [eos]\n10.0.0.1/32"
  ]
  "pe2" [
    label="pe2 [eos]\n10.0.0.2/32"
  ]
  "p1" [
    label="p1 [eos]\n10.0.0.3/32"
    fillcolor="#d1bfab"
  ]
  "p2" [
    label="p2 [eos]\n10.0.0.4/32"
    fillcolor="#d1bfab"
  ]
  "h1" [
    label="h1 [linux]\n172.16.0.5/24"
    fillcolor="#e3e3e3"
  ]
  "h2" [
    label="h2 [linux]\n172.16.1.6/24"
    fillcolor="#e3e3e3"
  ]
 "h1" -- "pe1"
 "pe1" -- "p1"
 "p1" -- "p2"
 "p2" -- "pe2"
 "pe2" -- "h2"
}
